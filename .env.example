# All keys are OPTIONAL. With none set, TriageWise runs in DEMO mode (realistic
# canned results) and never crashes. Set a model credential to go LIVE.

# Vercel AI Gateway key — routes every gateway model id (anthropic/..., meta/...).
# On Vercel you can instead rely on project OIDC and leave this unset.
AI_GATEWAY_API_KEY=

# Optional: call Anthropic directly instead of through the gateway.
ANTHROPIC_API_KEY=

# Optional: override the cheap/fast open model (any AI Gateway slug).
# TRIAGEWISE_CHEAP_MODEL=meta/llama-3.1-8b

# Optional: Supabase pgvector knowledge base. If unset (default), an in-memory
# lexical KB is used — no database required.
SUPABASE_URL=
SUPABASE_ANON_KEY=
