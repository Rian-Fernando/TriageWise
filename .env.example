# All keys are OPTIONAL. With none set, TriageWise runs in DEMO mode (realistic
# canned results) and never crashes. Set a model credential to go LIVE.

# Vercel AI Gateway key — routes every gateway model id (anthropic/..., meta/...).
# On Vercel you can instead rely on project OIDC and leave this unset.
AI_GATEWAY_API_KEY=

# Optional: call Anthropic directly instead of through the gateway.
ANTHROPIC_API_KEY=

# Optional: override the cheap/fast open model (any AI Gateway slug).
# TRIAGEWISE_CHEAP_MODEL=meta/llama-3.1-8b

# Supabase-backed knowledge base. Use your project URL + publishable (anon) key.
# If unset, an in-memory KB is used (no database required). Run supabase/schema.sql
# in the Supabase SQL editor once to create + seed the kb_entries table.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Optional: Resend — sends a real status email when a P1 is approved on the
# dashboard. Without these, the notification is simulated (still shown in the UI).
RESEND_API_KEY=
NOTIFY_DEMO_RECIPIENT=
# NOTIFY_FROM=TriageWise <onboarding@resend.dev>
